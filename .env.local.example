# 复制为 .env.local 后填入真实值（勿提交 .env.local 到仓库）
# 说明见 README.md「环境变量」章节

# ---------------------------------------------------------------------------
# 本地开发（必填）
# ---------------------------------------------------------------------------

# 讯飞星辰 Coding Plan MaaS（OpenAI 兼容，优先）
# 控制台 https://maas.xfyun.cn/packageSubscription
XFYUN_MAAS_API_KEY=your_app_id:your_api_secret
# XFYUN_MAAS_BASE_URL=https://maas-coding-api.cn-huabei-1.xf-yun.com/v2
# XFYUN_MAAS_MODEL=xsparkx2flash

# ChatAnywhere 免费 API（讯飞不可用时降级）https://github.com/chatanywhere/GPT_API_free
CHATANYWHERE_API_KEY=sk-your_chatanywhere_api_key

# DeepSeek 官方 API（AI 对话修改专用）https://platform.deepseek.com
DEEPSEEK_API_KEY=sk-your_deepseek_api_key
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-v4-flash
# MODIFY_CHAT_MODEL=deepseek-v4-flash

# 百度 OCR（简历导入 PDF/图片识别）https://ai.baidu.com/tech/ocr
BAIDU_OCR_API_KEY=your_baidu_api_key
BAIDU_OCR_SECRET_KEY=your_baidu_secret_key

# 百度短语音识别（语音输入，可与 OCR 共用同一应用的 API Key）
# BAIDU_SPEECH_API_KEY=your_baidu_api_key
# BAIDU_SPEECH_SECRET_KEY=your_baidu_secret_key

# ---------------------------------------------------------------------------
# 本地开发（可选）
# ---------------------------------------------------------------------------

# PDF/PNG 导出：Puppeteer 使用的浏览器路径；未设置时开发环境用 Puppeteer 自带 Chromium
# macOS:   /Applications/Google Chrome.app/Contents/MacOS/Google Chrome
# Windows: C:\Program Files\Google\Chrome\Application\chrome.exe
# Linux:   /usr/bin/chromium-browser
# PUPPETEER_EXECUTABLE_PATH=

# ---------------------------------------------------------------------------
# 部署专用（服务器上配置；NEXT_PUBLIC_* 需在 npm run build 前设置）
# ---------------------------------------------------------------------------

# 项目在服务器上的绝对路径（PM2 / 脚本工作目录）
# RESUME_PROJECT_ROOT=/root/easy-resume

# 站点对外访问根 URL
# NEXT_PUBLIC_SITE_URL=https://resume.example.com

# PDF 导出：Puppeteer 访问本机 Next（默认生产为 http://127.0.0.1:3010，勿经 Nginx 绕圈）
# EXPORT_BASE_URL=http://127.0.0.1:3010
# EXPORT_LOOPBACK_PORT=3010

# ---------------------------------------------------------------------------
# 可选：AI 评分限流与缓存（Upstash Redis 免费版）
# 在 https://console.upstash.com 创建 Database，复制 REST URL 和 TOKEN
# ---------------------------------------------------------------------------

# UPSTASH_REDIS_REST_URL=https://YOUR_URL.upstash.io
# UPSTASH_REDIS_REST_TOKEN=YOUR_TOKEN

# ---------------------------------------------------------------------------
# AI 请求体传输加密（RSA 公钥 + AES-256-GCM 混合）
# 生成密钥对：node scripts/gen-ai-payload-rsa-keys.mjs
# 私钥仅服务端；公钥可任选其一：
#   - runtime：AI_PAYLOAD_RSA_PUBLIC_KEY（PM2 配置即可，客户端运行时拉取）
#   - build 时：NEXT_PUBLIC_AI_PAYLOAD_RSA_PUBLIC_KEY（打入 bundle，少一次请求）
# 未配置时开发环境可明文 JSON；生产建议配置私钥 + 公钥
# ---------------------------------------------------------------------------

# AI_PAYLOAD_RSA_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----
# AI_PAYLOAD_RSA_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----
# NEXT_PUBLIC_AI_PAYLOAD_RSA_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----

# ---------------------------------------------------------------------------
# 可选：GitHub OAuth 登录（Auth.js / next-auth）
# 在 https://github.com/settings/developers 创建 OAuth App
# Authorization callback URL：
#   本地：http://localhost:3000/api/github/callback
#   生产：https://你的域名/api/github/callback
# ---------------------------------------------------------------------------

# AUTH_SECRET= # openssl rand -base64 32
# AUTH_GITHUB_ID=
# AUTH_GITHUB_SECRET=
# AUTH_TRUST_HOST=true
# 不要把 AUTH_URL 设成 NEXT_PUBLIC_SITE_URL；本地开发不设 AUTH_URL，回调会跟当前 host（localhost）走
# 生产若反代异常可设：AUTH_URL=https://resume.qdabuliuq.cn

# 后台账号密码登录（主站 /zh/admin → /api/admin/login，不在 Worker）
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=change-me-password
# ADMIN_SECRET=change-me-admin-secret
# CF_API_SECRET=change-me-cf-api-secret
# Worker 根地址（不要填主站域名；国内超时可改独立子域 api.resume…）
# 本地：CF_API_BASE_URL=http://127.0.0.1:8787
# 生产：CF_API_BASE_URL=https://easy-resume-db.easy-resume.workers.dev
