{
  "name": "easy-resume",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "lint:pritter": "prettier --write src/",
    "dev": "next dev",
    "clean:next": "rm -rf .next node_modules/.cache",
    "prebuild": "npm run clean:next",
    "build": "next build",
    "lint": "eslint src",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepare": "husky install",
    "start": "next start -p 3010"
  },
  "dependencies": {
